{
  "name": "ableton-vst-inventory",
  "type": "module",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc --noEmit && tsx build.ts --production",
    "build:dev": "tsc --noEmit && tsx build.ts",
    "start": "tsx build.ts && extensions-cli run --storage-directory ./.storage --temp-directory ./.temp",
    "package": "npm run build && extensions-cli package -o dist/ableton-vst-inventory.ablx"
  },
  "dependencies": {
    "@ableton-extensions/sdk": "file:extensions-sdk-1.0.0-beta.0/ableton-extensions-sdk-1.0.0-beta.0.tgz"
  },
  "devDependencies": {
    "@ableton-extensions/cli": "file:extensions-sdk-1.0.0-beta.0/ableton-extensions-cli-1.0.0-beta.0.tgz",
    "@types/node": "^22.20.1",
    "esbuild": "0.28.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  }
}
